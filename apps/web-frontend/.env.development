# Same-origin /api/... is proxied to https://api.noctuasky.com (see vue.config.js devServer). Works on any dev port.
VUE_APP_NOCTUASKY_API_SERVER=
# Uncomment to skip Wikipedia in selected-object info (same as production mainland builds).
# VUE_APP_DISABLE_WIKIPEDIA=1
# Optional: set in .env.development.local for mainland geocoding/search/IP fallback.
# VUE_APP_AMAP_WEB_SERVICE_KEY=
