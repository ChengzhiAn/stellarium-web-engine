VUE_APP_NOCTUASKY_API_SERVER="https://api.noctuasky.com"
# Wikipedia (en.wikipedia.org) is often slow or blocked in mainland China; skips the fetch for selected-object info.
VUE_APP_DISABLE_WIKIPEDIA=1
# Optional: set in .env.production.local for mainland geocoding/search/IP fallback.
# VUE_APP_AMAP_WEB_SERVICE_KEY=""
